{
  "name": "fluxer-bot",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gooop/fluxer-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gooop/fluxer-bot/issues"
  },
  "homepage": "https://github.com/gooop/fluxer-bot#readme",
  "dependencies": {
    "@discordjs/core": "2.4.0",
    "@discordjs/rest": "2.6.0",
    "@discordjs/ws": "2.0.4",
    "discord-message-builder": "file:packages/discord-message-builder"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
